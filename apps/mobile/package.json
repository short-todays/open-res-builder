{
  "name": "@open-resume-builder/mobile",
  "version": "1.0.0",
  "private": true,
  "description": "Open Resume Builder - Mobile Application (React Native Expo)",
  "scripts": {
    "dev": "expo start",
    "build": "expo build",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web"
  },
  "dependencies": {
    "@open-resume-builder/shared": "workspace:*",
    "expo": "^51.0.0",
    "expo-router": "^3.4.0",
    "react": "^19.0.0-rc-66051c87-20250101",
    "react-native": "^0.76.0-rc.0",
    "react-native-gesture-handler": "^2.17.0",
    "react-native-reanimated": "^3.10.0",
    "react-native-screens": "^4.0.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.23.0",
    "@babel/preset-typescript": "^7.23.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0-rc.0",
    "@types/react-native": "^0.76.0",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "typescript": "~5.8.3"
  },
  "expo": {
    "plugins": [
      "expo-router"
    ]
  }
}